# Environment variables

# ── Option A: GitHub Copilot (preferred — uses your Copilot license) ──────────
# Requires a GitHub Copilot subscription (Individual, Business, or Enterprise).
# Get your token:
#   1. Install GitHub CLI: brew install gh
#   2. Authenticate: gh auth login
#   3. Get token: gh auth token
# Or create a PAT at github.com/settings/tokens with copilot scope.
GITHUB_COPILOT_TOKEN=your_github_copilot_token_here
COPILOT_MODEL=gpt-4o            # optional, defaults to gpt-4o
# Set to "true" to use the @github/copilot-sdk (spawns Copilot CLI agent).
# When false or unset, Copilot is called via plain REST API.
USE_COPILOT_SDK=false

# ── Option B: GitHub Models (free tier available) ─────────────────────────────
# 1. Go to github.com/settings/tokens → Generate new token (classic)
# 2. No special scopes needed for public models (or add 'models:read' if prompted)
# 3. Available models: openai/gpt-4o, openai/gpt-4o-mini, meta/Llama-3.3-70B-Instruct
#    Full list: https://github.com/marketplace/models
GITHUB_TOKEN=github_pat_your_token_here
GITHUB_MODEL=gpt-4o           # optional, defaults to gpt-4o

# ── Option C: Azure OpenAI ────────────────────────────────────────────────────
# Azure Portal → your OpenAI resource → Keys and Endpoint
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE-NAME.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_key_here
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# ── Option D: Standard OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=your_openai_api_key_here

# Priority: Copilot → Azure → GitHub Models → OpenAI → mock/demo mode

# Database URL (SQLite for local dev)
DATABASE_URL="file:./dev.db"

# App URL (used in Teams escalation links)
APP_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3001

# ── Integrations ──────────────────────────────────────────────────────────────
# Microsoft Teams incoming webhook URL for overdue approval escalations
# Set up via: Teams channel → ... → Connectors → Incoming Webhook
TEAMS_WEBHOOK_URL=https://your-org.webhook.office.com/webhookb2/your-webhook-id
